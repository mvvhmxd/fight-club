# ─── Database ────────────────────────────────────────────────────────────────
# MySQL or TiDB connection string
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/fightclub

# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign session JWT cookies. Use a long random string.
# Generate one with: openssl rand -base64 32
JWT_SECRET=your-secret-here

# Manus OAuth credentials (managed automatically when deploying on Manus)
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im

# ─── Owner ───────────────────────────────────────────────────────────────────
# The Manus openId of the project owner. This user is auto-promoted to admin
# on first login. Find your openId in the Manus account settings.
OWNER_OPEN_ID=your-manus-open-id
OWNER_NAME=Your Name

# ─── Manus Built-in APIs ─────────────────────────────────────────────────────
# These are injected automatically when deploying on Manus.
# If self-hosting outside Manus, you can leave these blank — notifications
# and the Heartbeat cron will be disabled, but the core app will still work.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Umami analytics. Leave blank to disable.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
